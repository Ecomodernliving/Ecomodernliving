# Site
NEXT_PUBLIC_SITE_URL=https://ecomodernliving.ai
NEXT_PUBLIC_CONTACT_EMAIL=hello@ecomodernliving.ai

# Auth — set a long random string in production (e.g. openssl rand -base64 32)
AUTH_SECRET=

# Marketplace admin (can edit Top Picks products when signed in)
ADMIN_EMAIL=ecomodernliving@gmail.com

# Optional — auto-email energy audit estimates to users (https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=EcoModern Living <hello@ecomodernliving.ai>

# Amazon Associates tag (e.g. ecomodernliving-20)
NEXT_PUBLIC_AMAZON_AFFILIATE_TAG=

# Formspree form IDs (bare ID e.g. mbdvljqr, or full https://formspree.io/f/... URL)
NEXT_PUBLIC_FORMSPREE_CONTACT_ID=
NEXT_PUBLIC_FORMSPREE_NEWSLETTER_ID=
NEXT_PUBLIC_FORMSPREE_AUDIT_ID=

# Google Sheet product catalog (optional — lets non-technical users edit products in a spreadsheet)
# Publish sheet: File → Share → Publish to web → CSV → copy URL here
MARKETPLACE_SHEET_CSV_URL=

NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/@EcoModernLiving
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/ecomodernliving
NEXT_PUBLIC_FACEBOOK_URL=https://www.facebook.com/ecomodernliving
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/company/ecomodernliving
NEXT_PUBLIC_TIKTOK_URL=https://www.tiktok.com/@ecomodernliving
NEXT_PUBLIC_PINTEREST_URL=https://www.pinterest.com/ecomodernliving
NEXT_PUBLIC_DISCORD_URL=https://discord.gg/ecomodernliving
